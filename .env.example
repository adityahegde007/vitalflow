# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# DATABASE_URL: Connection string for the database (PostgreSQL/AlloyDB).
# Format: postgresql://user:password@host:port/dbname
# Recommended SSL query params:
# - Strong default behavior: ?sslmode=verify-full
# - libpq-compatible require semantics: ?uselibpqcompat=true&sslmode=require
DATABASE_URL=''
GOOGLE_CLOUD_PROJECT=''

# Security / abuse controls
# Set to comma-separated origins for browser access, e.g. https://your-app.run.app,https://yourdomain.com
CORS_ORIGINS=''
# Keep false for production unless you intentionally want wildcard CORS
CORS_ALLOW_ALL=false
# Restrict max JSON payload size
JSON_LIMIT='1Mb'
# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_WRITE_MAX=40
# Health endpoint verbosity (false recommended in production)
HEALTH_VERBOSE=false
# Dev server mode (false in production)
USE_VITE_DEV_SERVER=false
