# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VERTEX_KEY: Required for Vertex AI API calls (Service Account JSON).
VERTEX_KEY=
# VERTEX_PROJECT_ID: Optional override for the Google Cloud Project ID.
VERTEX_PROJECT_ID=
# VERTEX_LOCATION: Optional override for the Vertex AI region (default: us-central1).
VERTEX_LOCATION=
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_USE_VERTEX: Set to true to force using the Vertex AI backend proxy.
VITE_USE_VERTEX=false

# DATABASE_URL: Connection string for the database (PostgreSQL/AlloyDB).
# Format: postgresql://user:password@host:port/dbname
# Recommended SSL query params:
# - Strong default behavior: ?sslmode=verify-full
# - libpq-compatible require semantics: ?uselibpqcompat=true&sslmode=require
DATABASE_URL=
